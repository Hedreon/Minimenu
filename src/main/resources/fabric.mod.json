{
    "schemaVersion": 1,
    "id": "minimenu",
    "version": "${version}",
    "name": "Minimenu",
    "description": "Declutters screens like the title screen through configurable options.",
    "authors": [
        "TomB_134",
        "Hedreon"
    ],
    "contributors": [
        "jackassmc",
        "umollu",
        "huiki",
        "TGODiamond"
    ],
    "contact": {
        "issues" : "https://github.com/Hedreon/Minimenu/issues",
        "sources": "https://github.com/Hedreon/Minimenu"
    },
    "license": "MIT",
    "icon": "assets/minimenu/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "org.minimalmenu.Minimenu"
        ],
        "modmenu": [
            "org.minimalmenu.options.Integration"
        ]
    },
    "mixins": [
        "minimenu.mixins.json"
    ],
    "depends": {
        "java": ">=25",
        "minecraft": "~${minecraft_version}",
        "fabricloader": ">=${loader_version}",
        "fabric-api": ">=${fabric_api_version}",
        "modmenu": ">=${mod_menu_version}",
        "yet_another_config_lib_v3": ">=${yacl_version}"
    }
}